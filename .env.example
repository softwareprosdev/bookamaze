# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bookamaze

# WorkOS Auth
VITE_WORKOS_CLIENT_ID=
VITE_WORKOS_API_HOSTNAME=api.workos.com

# App URL (used for OAuth callbacks)
VITE_APP_URL=http://localhost:3000

# Token Encryption (32-character key for AES-256)
TOKEN_ENCRYPTION_KEY=your-32-character-encryption-key-here

# Optional error tracking
SENTRY_DSN=

# Google Drive OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dropbox OAuth
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
