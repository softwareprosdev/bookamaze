# Local database file path
DATABASE_PATH=./data/bookamaze.db

# Application URL
VITE_APP_URL=http://localhost:3000

# JWT secret used to sign session cookies
JWT_SECRET=your-32-character-secret-here

# Optional token encryption key for future features
TOKEN_ENCRYPTION_KEY=your-32-character-encryption-key-here

# Optional Sentry DSN for client-side error tracking
VITE_SENTRY_DSN=
